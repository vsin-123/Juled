# GitHub App Configuration
GITHUB_APP_ID=your-github-app-id
GITHUB_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Security - Encryption Keys (Required)
# Generate a 32-character key: openssl rand -hex 16
ENCRYPTION_KEY=your-32-character-encryption-key-here
SESSION_SECRET=your-session-secret-here

# AI Provider API Keys (Optional - configure via web interface or config file)
OPENAI_API_KEY=sk-your-openai-api-key-here
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Server Configuration
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_FORMAT=text
LOG_DESTINATION=logs/app.log

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=data/scanner.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100