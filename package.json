{
  "name": "pr-security-scanner",
  "version": "1.0.0",
  "description": "Comprehensive GitHub PR Security Scanner Bot for all file types with AI-powered analysis",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "start-server": "ts-node src/server.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "security",
    "scanner",
    "github",
    "pr",
    "owasp",
    "vulnerability",
    "sast",
    "ai"
  ],
  "author": "Security Team",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@octokit/rest": "^20.0.2",
    "yaml": "^2.3.4",
    "fast-xml-parser": "^4.3.2",
    "csv-parse": "^5.5.3",
    "minimatch": "^9.0.3",
    "glob": "^10.3.10",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "axios": "^1.6.2",
    "semver": "^7.5.4",
    "json5": "^2.2.3",
    "ini": "^4.1.1",
    "openai": "^4.28.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/jest": "^29.5.11",
    "@types/ini": "^4.1.0",
    "@types/semver": "^7.5.6",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1"
  }
}
